# Environment Variables — Simons Unified Commerce Signal Agent
#
# Copy this file to .env and fill in values when real credentials are available.
# DO NOT commit .env to version control.
#
# CURRENT STATE: No environment variables are required.
# All adapters are mocked with local fixture data.
# No external services are called.
#
# These variables are placeholders for Phase 2 (Bloomreach sandbox integration).

# --- Bloomreach Loomi Connect MCP — Transport (Phase 2) ---
#
# Loomi Connect MCP uses Streamable HTTP transport with browser-based Bloomreach
# authentication. See docs/mcp-integration-plan.md for transport and auth details.
#
# Analytics MCP and Marketing MCP share one endpoint; Conversations MCP uses a
# separate endpoint. Confirm exact URLs from the Bloomreach sandbox portal.
#
# LOOMI_MCP_ANALYTICS_MARKETING_URL=
# LOOMI_MCP_CONVERSATIONS_URL=
#
# Authentication mode (default: browser — programmatic token auth is TBD).
# Change only if Bloomreach confirms token-based programmatic access.
# LOOMI_MCP_AUTH_MODE=browser
#
# Optional / TBD: session token for programmatic discovery.
# Only set this if Bloomreach confirms that token-based programmatic auth works
# outside of a browser-auth MCP client. Do NOT set this from a guess.
# LOOMI_MCP_TOKEN=
#
# Feature flag — controls whether the app uses live or mock MCP adapters.
# Default: false (mock). Set to true ONLY after schema is confirmed via discovery.
# The Streamlit app does NOT read this variable. It is for scripts/ only in Phase D.1.
# LOOMI_MCP_LIVE=false

# --- Gemini / Vertex AI Reasoning Engine (Phase 2) ---
# GEMINI_API_KEY=
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=

# --- Internal Ops Data (Phase 3) ---
# OPS_OBSERVABILITY_ENDPOINT=
# OMS_API_ENDPOINT=

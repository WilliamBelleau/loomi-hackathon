# Environment Variables — Simons Unified Commerce Signal Agent
#
# Copy this file to .env and fill in values when real credentials are available.
# DO NOT commit .env to version control. DO NOT commit endpoint URLs or tokens.
#
# CURRENT STATE: No environment variables are required.
# All adapters are mocked with local fixture data.
# No external services are called from the Streamlit app.
#
# These variables are placeholders for Phase D.2/D.3 (Bloomreach sandbox integration).
# They are safe to leave commented out. They must never be committed with real values.

# --- Bloomreach Loomi Connect MCP — Transport (Phase D.2/D.3) ---
#
# Loomi Connect MCP uses Streamable HTTP transport with browser-based Bloomreach
# SSO / OIDC authentication. No API keys or custom headers are required for normal use.
# Authentication is triggered automatically on the first tool call in your MCP client.
#
# RECOMMENDED: Configure these URLs in your MCP-compatible IDE client (Antigravity,
# Claude Code, Cursor, VS Code with MCP extension). Do NOT paste values here unless
# you are certain the .env file is gitignored and you understand the security implications.
#
# Analytics MCP and Marketing MCP share one endpoint.
# Conversations MCP is a separate server.
# Exact URLs come from the Bloomreach sandbox portal (shared via hackathon Slack).
#
# LOOMI_MCP_ANALYTICS_MARKETING_URL=
# LOOMI_MCP_CONVERSATIONS_URL=
#
# Authentication mode — leave as "browser" unless otherwise confirmed.
# Normal Loomi Connect auth is browser-based SSO. No token is needed.
# LOOMI_MCP_AUTH_MODE=browser
#
# Token — NOT RECOMMENDED. Token-based programmatic access is not a confirmed
# Bloomreach-supported pattern. Only set this if Bloomreach explicitly provides
# token-based access instructions for standalone scripts. Do not guess or infer a token.
# LOOMI_MCP_TOKEN=
#
# Feature flag — Phase D.3 only. Controls whether the app uses live or mock adapters.
# Default: false (mock). The Streamlit app does NOT read this variable.
# Only scripts/ and future live adapters will read this flag.
# LOOMI_MCP_LIVE=false

# --- Gemini / Vertex AI Reasoning Engine (Phase 2) ---
# GEMINI_API_KEY=
# VERTEX_PROJECT_ID=
# VERTEX_LOCATION=

# --- Internal Ops Data (Phase 3) ---
# OPS_OBSERVABILITY_ENDPOINT=
# OMS_API_ENDPOINT=
